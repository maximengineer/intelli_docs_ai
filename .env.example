# --- Core ---
APP_NAME=IntelliDocs AI
MAX_UPLOAD_MB=10
MAX_DOCUMENTS=10
PARSER_TIMEOUT_SECONDS=10
CORS_ORIGINS=["http://localhost:9999","http://127.0.0.1:9999","http://localhost:8501","http://127.0.0.1:8501"]

# --- LLM provider (OpenRouter, OpenAI-compatible) ---
# Leave ENABLE_LLM=false (or omit the key) to run with the deterministic
# extractive fallback. Set both to turn on generative summaries, structured
# extraction and LLM-written cited answers.
ENABLE_LLM=false
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-v4-flash
LLM_REFERER=http://localhost:9999
# Fail instead of using heuristic/hash fallbacks when a configured provider call
# cannot be completed. The isolated live-test target forces this to true.
STRICT_PROVIDER_MODE=false

# --- Embeddings ---
# Backend options:
#   auto       -> OpenRouter embeddings if a key is set, else hash (default, light)
#   local      -> sentence-transformers: real semantic search, offline, no key.
#                 Requires: uv sync --extra local-embeddings  (pulls torch)
#   openrouter -> OpenRouter embeddings API
#   hash       -> zero-dependency lexical fallback (no semantics)
EMBEDDING_BACKEND=auto
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Phase 2 storage/readiness ---
# Local host value for running the API outside Docker. docker-compose overrides
# this to use the postgres service hostname from inside the backend container.
DATABASE_URL=postgresql://intellidocs:intellidocs@localhost:5432/intellidocs
REQUIRE_DATABASE_READY=false
VECTOR_STORE_BACKEND=memory
# Used by pgvector mode. Docker uses hash embeddings sized to this dimension for
# the no-key demo. If you switch to a real embedding model, set this to the
# model's dimension and run a matching migration.
POSTGRES_VECTOR_DIMENSION=1536
POSTGRES_VECTOR_DISTANCE_METRIC=cosine
POSTGRES_VECTOR_OPERATOR_CLASS=vector_cosine_ops
POSTGRES_VECTOR_INDEX_TYPE=hnsw
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=5
DATABASE_POOL_TIMEOUT_SECONDS=5

# --- Phase 2 cost estimation ---
# Prices are tied to LLM_MODEL; recheck OpenRouter before changing the model.
PRICE_TABLE_AS_OF=2026-06-21
LLM_INPUT_PRICE_PER_1M_TOKENS=0.0983
LLM_OUTPUT_PRICE_PER_1M_TOKENS=0.1966

# --- Phase 3 worker / streaming ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
DOCUMENT_PROCESSING_BACKEND=thread
UPLOAD_STORAGE_DIR=data/uploads
SUPPORT_CHECK_ENABLED=true
SUPPORT_CHECK_MIN_CITATION_COUNT=1
# Minimum shared content tokens between an answer and its cited chunk text.
SUPPORT_CHECK_MIN_OVERLAP=1
STREAMING_ENABLED=true
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=50
CELERY_TASK_TIME_LIMIT_SECONDS=60

# --- Opt-in live provider smoke tests ---
# `make live-test` uses hash embeddings and `make live-test-embeddings` forces
# OpenRouter embeddings. Both use an isolated Compose project and strict provider
# mode; these values are primarily useful when invoking the profile manually.
LIVE_EMBEDDING_BACKEND=hash
LIVE_REQUIRE_PROVIDER_EMBEDDINGS=false
LIVE_TEST_TIMEOUT_SECONDS=300
LIVE_HTTP_TIMEOUT_SECONDS=120
LIVE_POLL_DEADLINE_SECONDS=240
